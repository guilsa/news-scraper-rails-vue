# News Scraper Rails API - Environment Variables

# API Authentication Token (required for POST /api/v1/articles)
NEWS_SCRAPER_API_TOKEN=your_secure_random_token_here

# Database Configuration
DATABASE_URL=postgresql://newscraper:password@rails-postgres:5432/newscraper

# Rails Configuration
RAILS_ENV=production
RAILS_LOG_TO_STDOUT=true
RAILS_SERVE_STATIC_FILES=true

# Rails Secret Key Base (generate with: bin/rails secret)
SECRET_KEY_BASE=your_secret_key_base_here

# Rails Master Key (for encrypted credentials)
# RAILS_MASTER_KEY=your_master_key_here
